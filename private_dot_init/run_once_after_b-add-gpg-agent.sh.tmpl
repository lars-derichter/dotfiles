#!/bin/sh
set -e

{{ if eq .chezmoi.os "darwin" -}}
# Ensure gnupg is installed
if ! command -v gpg &>/dev/null; then
    echo "gpg is not installed. Installing..."
    brew install gnupg
fi

# Guard: private key must exist (fetched from 1Password by chezmoi template)
if [ ! -f "$HOME/.gnupg/private.key" ]; then
    echo "WARNING: ~/.gnupg/private.key not found. GPG setup skipped."
    echo "Check that 1Password CLI is authenticated and re-run chezmoi apply."
    exit 0
fi

{{ output "brew" "--prefix" | trim }}/bin/gpg --import ~/.gnupg/private.key
expect -c "spawn {{ output "brew" "--prefix" | trim }}/bin/gpg --edit-key {{ .gpg_key_id }} trust quit; send \"5\ry\r\"; expect eof"
rm ~/.gnupg/private.key

echo "\nCheck if key is shown with ultimate trust and correct identity"
{{ output "brew" "--prefix" | trim }}/bin/gpg --list-keys

# (re)start gpg-agent
killall gpg-agent || true
gpg-agent --daemon
{{- end }}
