#!/bin/sh
set -e

{{ if eq .chezmoi.os "darwin" -}}
# Set the hostname using the chezmoi variable
sudo scutil --set HostName "{{ .preferredhostname }}"
sudo scutil --set LocalHostName "{{ .preferredhostname }}"
sudo scutil --set ComputerName "{{ .preferredhostname }}"

# Add hostname entry to /etc/hosts (preserve existing localhost line)
if ! grep -q "{{ .preferredhostname }}" /etc/hosts; then
    echo "127.0.0.1       {{ .preferredhostname }}.local {{ .preferredhostname }}" | sudo tee -a /etc/hosts > /dev/null
fi
{{ end -}}